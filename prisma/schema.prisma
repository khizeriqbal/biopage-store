generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  password         String?
  username         String    @unique
  name             String?
  bio              String?   @db.Text
  avatar           String?
  niche            String?
  onboardingDone   Boolean   @default(false)
  whopCompanyId    String?
  whopAccessToken  String?
  whopRefreshToken String?
  plan             Plan      @default(FREE)
  planExpiresAt    DateTime?
  customDomain     String?   @unique
  domainVerified   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products            Product[]
  orders              Order[]             @relation("SellerOrders")
  subscribers         Subscriber[]
  bookings            Booking[]           @relation("SellerBookings")
  pageSettings        PageSettings?
  analytics           Analytics[]
  accounts            Account[]
  sessions            Session[]
  coupons             Coupon[]
  bundles             Bundle[]
  affiliateLinks      AffiliateLink[]     @relation("CreatorAffiliates")
  emailSequences      EmailSequence[]
}

enum Plan {
  FREE
  STARTER
  CREATOR
  PRO
}

model Product {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ProductType
  priceType    PriceType   @default(FIXED)
  title        String
  slug         String
  description  String?     @db.Text
  price        Float       @default(0)
  minPrice     Float?
  comparePrice Float?
  coverImage   String?
  fileUrl      String?
  published    Boolean     @default(false)
  waitlisted   Boolean     @default(false)
  featured     Boolean     @default(false)
  salesCount   Int         @default(0)
  totalRevenue Float       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]
  lessons      Lesson[]
  bookingSlots BookingSlot[]
  reviews      Review[]
  waitlistEntries Waitlist[]
  bundleItems  BundleItem[]

  @@unique([userId, slug])
  @@index([userId, published])
}

enum ProductType {
  DIGITAL
  COURSE
  BOOKING
  MEMBERSHIP
  LEAD_MAGNET
}

enum PriceType {
  FIXED
  MINIMUM
  FREE
}

model Lesson {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title            String
  content          String?  @db.Text
  videoUrl         String?
  order            Int      @default(0)
  published        Boolean  @default(false)
  availableAfterDays Int    @default(0)
  createdAt        DateTime @default(now())

  @@index([productId, order])
}

model Order {
  id              String      @id @default(cuid())
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  sellerId        String
  seller          User        @relation("SellerOrders", fields: [sellerId], references: [id])
  buyerEmail      String
  buyerName       String?
  amount          Float
  currency        String      @default("usd")
  whopSessionId   String      @unique
  status          OrderStatus @default(PENDING)
  downloadCount   Int         @default(0)
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  affiliateLinkId String?
  affiliateLink   AffiliateLink? @relation(fields: [affiliateLinkId], references: [id])
  createdAt       DateTime    @default(now())

  affiliateEarnings AffiliateEarning[]
  review           Review?

  @@index([sellerId, createdAt])
  @@index([whopSessionId])
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
}

model Coupon {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  code          String       @unique
  discountType  DiscountType @default(PERCENT)
  discountValue Float
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  productIds    String[]     @default([])
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  orders        Order[]

  @@index([userId])
}

enum DiscountType {
  PERCENT
  FIXED
}

model Bundle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  bundlePrice Float
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  items       BundleItem[]

  @@index([userId])
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
}

model AffiliateLink {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation("CreatorAffiliates", fields: [userId], references: [id], onDelete: Cascade)
  affiliateEmail    String
  affiliateName     String?
  code              String   @unique
  commissionPercent Float    @default(30)
  approved          Boolean  @default(true)
  totalEarned       Float    @default(0)
  totalClicks       Int      @default(0)
  createdAt         DateTime @default(now())

  orders            Order[]
  earnings          AffiliateEarning[]

  @@index([userId])
}

model AffiliateEarning {
  id              String        @id @default(cuid())
  affiliateLinkId String
  affiliateLink   AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  amount          Float
  createdAt       DateTime      @default(now())

  @@index([affiliateLinkId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  rating     Int
  comment    String?  @db.Text
  buyerName  String?
  buyerEmail String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model Waitlist {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId])
}

model EmailSequence {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  trigger     SequenceTrigger @default(SUBSCRIBER_JOIN)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())

  steps       EmailStep[]
  enrollments SequenceEnrollment[]

  @@index([userId])
}

enum SequenceTrigger {
  SUBSCRIBER_JOIN
  POST_PURCHASE
}

model EmailStep {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  subject    String
  body       String        @db.Text
  delayDays  Int           @default(0)
  position   Int           @default(0)
  createdAt  DateTime      @default(now())

  @@index([sequenceId, position])
}

model SequenceEnrollment {
  id          String        @id @default(cuid())
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  email       String
  currentStep Int           @default(0)
  completed   Boolean       @default(false)
  enrolledAt  DateTime      @default(now())
  nextSendAt  DateTime?

  @@unique([sequenceId, email])
  @@index([sequenceId])
  @@index([nextSendAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  source    String?
  tags      String[] @default([])
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId])
}

model BookingSlot {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  available Boolean   @default(true)
  bookings  Booking[]

  @@index([productId, startTime])
}

model Booking {
  id          String      @id @default(cuid())
  slotId      String
  slot        BookingSlot @relation(fields: [slotId], references: [id])
  sellerId    String
  seller      User        @relation("SellerBookings", fields: [sellerId], references: [id])
  clientEmail String
  clientName  String
  notes       String?
  paid        Boolean     @default(false)
  meetLink    String?
  createdAt   DateTime    @default(now())

  @@index([sellerId])
}

model PageSettings {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme        String  @default("midnight")
  primaryColor String  @default("#5C4EFA")
  accentColor  String  @default("#C6FF4E")
  layout       Json    @default("[]")
  socialLinks  Json    @default("{}")
  customCSS    String? @db.Text
  seoTitle     String?
  seoDesc      String?
  published    Boolean @default(false)
}

model Analytics {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  pageViews Int      @default(0)
  clicks    Json     @default("{}")
  revenue   Float    @default(0)

  @@unique([userId, date])
  @@index([userId, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model JvPartner {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  skype     String?
  listSize  String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
