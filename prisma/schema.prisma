generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  username      String?   @unique
  bio           String?
  avatar        String?
  niche         String?
  onboardingDone Boolean   @default(false)
  customDomain  String?   @unique
  domainVerified Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Admin Fields
  role          String    @default("user")        // "user" | "admin" | "superadmin"
  isAdmin       Boolean   @default(false)         // Backward compatibility
  adminNotes    String?   @db.Text                // Internal admin notes
  suspendedAt   DateTime?                         // Null = active, DateTime = suspended
  lastSuspendedBy String?                         // Track which admin suspended
  suspendReason String?                           // Why was user suspended

  // Relations
  accounts      Account[]
  sessions      Session[]
  products      Product[]
  orders        Order[]
  subscribers   Subscriber[]
  emailSequences EmailSequence[]
  pageSettings  PageSettings[]
  analytics     Analytics[]
  bundles       Bundle[]
  affiliateLinks AffiliateLink[]
  coupons       Coupon[]
  bookings      Booking[]
  adminLogs     AdminLog[] @relation("AdminUser")

  // Payment Relations
  wallet        CreatorWallet?
  withdrawals   WithdrawalRequest[] @relation("WithdrawalRequests")
  approvedWithdrawals WithdrawalRequest[] @relation("ApprovedWithdrawals")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Product Models
model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?  @db.Text
  price          Float
  currency       String   @default("USD")
  type           ProductType @default(DIGITAL)
  priceType      PriceType @default(ONE_TIME)
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  published      Boolean  @default(false)

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         Order[]
  reviews        Review[]
  bundleItems    BundleItem[]
  lessons        Lesson[]

  @@index([userId])
}

enum ProductType {
  DIGITAL
  COURSE
  SERVICE
  PHYSICAL
}

enum PriceType {
  ONE_TIME
  SUBSCRIPTION
  PAY_WHAT_YOU_WANT
}

model Lesson {
  id        String   @id @default(cuid())
  productId String
  title     String
  content   String?  @db.Text
  order     Int
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  customerEmail   String
  customerName    String?
  amount          Float
  currency        String   @default("USD")
  status          String   @default("pending")
  paymentId       String?
  affiliateLinkId String?

  // Commission tracking
  platformFee     Float    @default(0.0)     // Amount platform keeps
  creatorEarning  Float    @default(0.0)     // Amount creator gets
  commissionRate  Float    @default(0.3)     // Commission percentage (e.g., 0.3 = 30%)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  affiliateLink   AffiliateLink? @relation(fields: [affiliateLinkId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([affiliateLinkId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Coupon {
  id       String   @id @default(cuid())
  userId   String
  code     String   @unique
  discount Float
  type     String   @default("PERCENTAGE")
  maxUses  Int?
  used     Int      @default(0)
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bundle Models
model Bundle {
  id        String   @id @default(cuid())
  userId    String
  name      String
  description String? @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     BundleItem[]

  @@index([userId])
}

model BundleItem {
  id       String @id @default(cuid())
  bundleId String
  productId String

  bundle   Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([bundleId])
  @@index([productId])
}

// Subscriber Models
model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  tags      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments SequenceEnrollment[]

  @@unique([userId, email])
  @@index([userId])
}

// Email Automation
model EmailSequence {
  id        String   @id @default(cuid())
  userId    String
  name      String
  trigger   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps     EmailStep[]
  enrollments SequenceEnrollment[]

  @@index([userId])
}

model EmailStep {
  id         String   @id @default(cuid())
  sequenceId String
  subject    String
  body       String   @db.Text
  delay      Int      @default(0)
  order      Int

  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id         String   @id @default(cuid())
  subscriberId String
  sequenceId String
  enrolledAt DateTime @default(now())

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@index([sequenceId])
}

// Page Customization
model PageSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  bgColor        String   @default("#000000")
  textColor      String   @default("#ffffff")
  accentColor    String   @default("#6366f1")
  logoUrl        String?
  customCSS      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Analytics
model Analytics {
  id        String   @id @default(cuid())
  userId    String
  pageView  Int      @default(0)
  click     Int      @default(0)
  date      DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Affiliate System
model AffiliateLink {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  earnings  AffiliateEarning[]

  @@index([userId])
}

model AffiliateEarning {
  id             String   @id @default(cuid())
  affiliateLinkId String
  amount         Float
  createdAt      DateTime @default(now())

  affiliateLink  AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@index([affiliateLinkId])
}

// Booking System
model Booking {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String
  slotId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      BookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slotId])
}

model BookingSlot {
  id        String   @id @default(cuid())
  date      DateTime
  duration  Int
  available Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings  Booking[]

  @@index([date])
}

// Waitlist
model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

// JV Partner Model (for WarriorPlus/JVZoo launches)
model JvPartner {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  skype     String?
  list      String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Admin Audit Log
model AdminLog {
  id           String   @id @default(cuid())
  adminId      String                         // Who performed the action
  action       String                         // "suspend", "promote", "update", etc.
  entityType   String                         // "user", "product", "order"
  entityId     String                         // ID of what was affected
  oldValues    String?  @db.Text              // JSON of previous values
  newValues    String?  @db.Text              // JSON of new values
  reason       String?  @db.Text              // Why was this action taken
  ipAddress    String?                        // For security tracking
  createdAt    DateTime @default(now())

  admin        User     @relation("AdminUser", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// Payment & Earnings System
model CreatorWallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Float    @default(0.0)       // Available to withdraw
  totalEarned   Float    @default(0.0)       // Lifetime earnings
  lastUpdated   DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
}

model WalletTransaction {
  id            String   @id @default(cuid())
  walletId      String
  type          String                       // "SALE", "WITHDRAWAL", "REFUND", "ADJUSTMENT"
  amount        Float
  orderId       String?                      // If from a sale
  withdrawalId  String?                      // If withdrawal
  description   String?
  createdAt     DateTime @default(now())

  wallet        CreatorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  bankAccount   String?                      // Account info they want withdrawal to
  requestedAt   DateTime @default(now())
  approvedAt    DateTime?
  approvedBy    String?                      // Admin who approved
  completedAt   DateTime?
  reason        String?                      // Admin notes

  user          User     @relation("WithdrawalRequests", fields: [userId], references: [id], onDelete: Cascade)
  approver      User?    @relation("ApprovedWithdrawals", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

model PlatformConfig {
  id            String   @id @default(cuid())
  key           String   @unique             // e.g., "PRODUCT_COMMISSION", "COURSE_COMMISSION"
  value         String                       // Store as JSON string
  description   String?
  updatedAt     DateTime @updatedAt

  @@index([key])
}
